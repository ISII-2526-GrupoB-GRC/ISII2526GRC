@page "/purchase/createpurchase"



@inject NavigationManager navigation
@using AppForSEII2526.Web.Components.Shared
@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using AppForSEII2526.Web.API
@using Microsoft.AspNetCore.Authorization
@inject AppForSEII2526APIClient aPIClient
@inject ILogger<CreatePurchase> logger
@inject PurchaseStateContainer PurchaseState


@*@attribute [Authorize]*@

@* purchase is the object that will be edited thanks to the form*@

<h3>CreatePurchase</h3>
<EditForm Model="purchase" OnValidSubmit="OpenDialog">
    <div class="row">

        <DataAnnotationsValidator />
        <ValidationSummary />
        <ValidationSummary class="row alert alert-danger"></ValidationSummary>
            </div>
            <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
                <p id="ErrorsShown">Errors: @messageError></p>
            </div>

    <div class="row g-3">


        <div class="col-md">


            <div class="form-floating mb-3">


                <InputText @bind-Value="purchase.Name" class="form-control" id="Name" />


                <label for="Name">Name </label>


            </div>


        </div>


        <div class="col-md">


            <div class="form-floating mb-3">


                <InputText @bind-Value="purchase.Surnames" class="form-control" id="Surname" />


                <label for="Surname">Surnames </label>


            </div>


        </div>


        <div class="col-md">


            <div class="form-floating mb-3">


                <InputText @bind-Value="purchase.DeliveryAddress" class="form-control" id="DeliveryAddress" />


                <label for="DeliveryAddress">Delivery Address</label>


            </div>


        </div>


    </div>


    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="purchase.PaymentMethod" id="PaymentMethod">
                    <option value="@PaymentMethodTypes.CreditCard" default> CreditCard</option>
                    <option value="@PaymentMethodTypes.PayPal"> Paypal</option>
                    <option value="@PaymentMethodTypes.Cash"> Cash</option>
                </InputSelect>
                <laber for="PaymentMethod">Payment Method</laber>
            </div>
        </div>
    </div>

        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to purchase de devices*@
                <button class="btn btn-primary" type="submit" id="Submit">
                    Purchase your devices
                </button>
            </div>
        </div>
    

        <h4>Purchase detail</h4>
        <p>
            <b>Total price:</b>@TotalCost €
            <button class="btn btn-outline-primary" type="submit" @onclick="ModifyPurchaseItems" id="ModifyDevices">
                Modify devices
            </button>

        </p>

    <div class="mh-100 table-responsive">
        <table class="table table-condesed table-hover" id="TableOfPurchaseDevices">
            <thead>
                <tr>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Colour</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var device in purchase.PurchaseItems)
                {
                    <tr id="DeviceData_@device.NameModel">
                        <td>@device.Brand</td>
                        <td>@device.NameModel</td>
                        <td>@device.Colour</td>
                        <td>@device.Price</td>
                        <td><InputNumber @bind-Value="device.Quantity" class="form-control" id="@($"quantity_{device.NameModel}")" /></td>
                        <td><InputText @bind-Value="device.Description" class="form-control" id="@($"description_{device.NameModel}")" /></td>
                        
                    </tr>
                }
            </tbody>
        </table>
    </div>

</EditForm>

@*a modal popup dialog for checking if user wants to proceed to buy*@

@if (DialogIsOpen)
{
    <Dialog Caption="Purchase devices"
    Message="Do you want to proceed to purchase the selected devices?"
    onclose="@OnDialogClose"
    Type=Dialog.Category.SaveNot>
    </Dialog>    

}

@code {

    private string messageError = "";
    private bool hideErrors {get{return messageError.Length == 0;}}
    private PurchaseForCreateDTO purchase => PurchaseState.Purchase;
    private bool DialogIsOpen;
    private object? errors;

    private decimal TotalCost
    {
        get{
            double price = purchase.PurchaseItems.Sum(item => item.Price * item.Quantity);
            return Convert.ToDecimal(price);
        }

    }

    private void ModifyPurchaseItems()
    {
        navigation.NavigateTo("/purchase/selectdevicesforpurchase");
    }

    private void OpenDialog()
    {
        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {
        DialogIsOpen = false;
        if(isOk)
        {

            try
            {
                //we proceed to create the purchase
                if(purchase.PurchaseItems.Count > 0)
                {
                    var purchased = await aPIClient.CreatePurchaseAsync(purchase);
                    PurchaseState.PurchaseProcessed();
                    navigation.NavigateTo($"/purchase/detailpurchase/?PurchaseID={purchased.Id}");
                }

            }
            catch(ApiException<ValidationProblemDetails> apiexceptionvalidation)
            {
                if(apiexceptionvalidation.Result.Errors.Values != null){
                    messageError = "";
                    foreach(var errors in apiexceptionvalidation.Result.Errors.Values)

                        messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                }

            }
            catch (ApiException apiexception) {


                //we need to inform user that there was some other error while processing the request


                messageError = apiexception.Message;
                Console.WriteLine(apiexception.Message);





            }

        }
    }


    protected override async Task OnInitializedAsync()
    {
        if (authentificationState is not null)
        {
            var authState = await authentificationState;
            var user = authState?.User;

            if (user.Identity is not null && user.Identity.IsAuthenticated)
            {
                purchase.Name = user.Identity.Name;
            }
            purchase.Name = purchase.Name == null ? "" : purchase.Name;
            purchase.Surnames = purchase.Surnames == null ? "" : purchase.Surnames;
            purchase.DeliveryAddress = purchase.DeliveryAddress == null ? "" : purchase.DeliveryAddress;
        } 
    }
    [CascadingParameter]
    private Task<AuthenticationState>? authentificationState{ get; set; }

}